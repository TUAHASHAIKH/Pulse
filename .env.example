# ─── GitHub ───
GITHUB_TOKEN=                    # Personal Access Token (from pulse init)
GITHUB_WEBHOOK_SECRET=           # Auto-generated by pulse init
GITHUB_APP_ID=                   # Optional: GitHub App ID (alternative to PAT)
GITHUB_PRIVATE_KEY_PATH=         # Optional: Path to GitHub App private key

# ─── LLM API ───
LLM_API_KEY=                     # Your Anthropic or OpenAI API key
LLM_PROVIDER=anthropic           # anthropic | openai

# ─── Orchestrator ───
ORCHESTRATOR_PORT=8000
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── Dashboard ───
DASHBOARD_PORT=3000
DASHBOARD_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────
# NOTE: End users don't need this file.
# Run `pulse init` instead — it creates .pulse/config.json
# with all your settings through an interactive wizard.
# This .env file is for developers working on Pulse itself.
# ─────────────────────────────────────────────────
